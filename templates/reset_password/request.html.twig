{% extends 'base.html.twig' %}

{% block title %}{{ 'reset_password.request_title'|trans }}{% endblock %}

{% block body %}
    <main class="login container-lg d-flex justify-content-center mt-2 justify-content-center">
        {% for flash_error in app.flashes('reset_password_error') %}
            <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
        {% endfor %}
        <section class="mt-4">
            <h1 class="text-center">{{ 'reset_password.request_title'|trans }}</h1>

            {{ form_start(requestForm) }}
            {{ form_row(requestForm.email) }}
            <div>
                <small>
                    {{ 'reset_password.help'|trans }}
                </small>
            </div>

            <button class="btn btn-primary mt-2">{{ 'reset_password.request_button'|trans }}</button>
            {{ form_end(requestForm) }}
        </section>

    </main>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.music_style.edit'|trans({'name': music_style.name}) }}{% endblock %}

{% block body %}
    <main class="adminForms container-lg">
        <h1>{{ 'admin.music_style.edit'|trans({'name': music_style.name}) }}</h1>

        {{ include('admin/music_style/_form.html.twig', {'button_label': 'action.save'|trans}) }}

        <div class="d-flex justify-content-start">
            <a class="btn btn-primary me-2" href="{{ path('admin_musicStyle_index') }}">{{ 'action.back_to_list'|trans }}</a>
            {{ include('admin/music_style/_delete_form.html.twig') }}
        </div>
    </main>
{% endblock %}

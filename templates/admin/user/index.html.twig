{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.user.list'|trans }}{% endblock %}

{% block body %}
    <main class="adminItemIndex container-lg">

        <h1>{{ 'admin.user.list'|trans }}</h1>
        <div class="d-flex justify-content-end gap-2  mb-2">
            <a class="btn btn-primary" href="{{ path('admin_user_new') }}">{{ 'admin.user.add'|trans }}</a>
            <a class="btn btn-info" href="{{ path('admin_board') }}">{{ 'action.admin_home'|trans }}</a>
        </div>


        <table class="table">
            <thead>
            <tr>
                <th>{{ 'admin.table.id'|trans }}</th>
                <th>{{ 'admin.table.name'|trans }}</th>
                <th>{{ 'admin.table.email'|trans }}</th>
                <th>{{ 'admin.table.roles'|trans }}</th>
                <th></th>
            </tr>
            </thead>
            <tbody>
            {% for user in users %}
                <tr>
                    <td>{{ user.id }}</td>
                    <td class="largeContent">{{ user.lastname }} {{ user.firstname }}</td>
                    <td>{{ user.email }}</td>
                    <td class="largeContent">{{ user.roles|join(' | ') }}</td>
                    <td class="d-flex flex-row">
                        <a class="btn btn-warning" href="{{ path('admin_user_resend_invite', {'user': user.id}) }}">{{ 'action.resend_invite'|trans }}</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7">{{ 'admin.user.none'|trans }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

    </main>
{% endblock %}

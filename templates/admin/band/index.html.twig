{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.band.list'|trans }}{% endblock %}

{% block body %}
    <main class="adminItemIndex container-lg">

        <h1>{{ 'admin.band.list'|trans }}</h1>
        <div class="d-flex justify-content-end gap-2  mb-2">
            <a class="btn btn-primary" href="{{ path('admin_band_new') }}">{{ 'admin.band.add'|trans }}</a>
            <a class="btn btn-info" href="{{ path('admin_board') }}">{{ 'action.admin_home'|trans }}</a>
        </div>


        <table class="table">
            <thead>
            <tr>
                <th>{{ 'admin.table.name'|trans }}</th>
                <th>{{ 'admin.table.description'|trans }}</th>
                <th>{{ 'admin.table.active'|trans }}</th>
                <th>{{ 'admin.table.flash_information'|trans }}</th>
                <th>{{ 'admin.table.tagline'|trans }}</th>
                <th></th>
            </tr>
            </thead>
            <tbody>
            {% for band in bands %}
                <tr>
                    <td>{{ band.name }}</td>
                    <td class="largeContent">{{ band.description }}</td>
                    <td>{{ band.isActive ? 'Actif' : 'Inactif' }}</td>
                    <td class="largeContent">{{ band.flashInformation }}</td>
                    <td class="largeContent">{{ band.tagline }}</td>
                    <td class="d-flex flex-row">
                        <a class="btn btn-primary" href="{{ path('band_show', {'slug': band.slug}) }}" target="_blank">{{ 'action.consult'|trans }}</a>
                        <a class="btn btn-warning" href="{{ path('admin_band_edit', {'id': band.id}) }}">{{ 'action.edit'|trans }}</a>
                        <a class="btn btn-info" href="{{ path('admin_band_media', {'id': band.id}) }}">{{ 'action.medias'|trans }}</a>
                        <a class="btn btn-secondary" href="{{ path('admin_band_concert', {'band': band.id}) }}">{{ 'admin.band.concerts'|trans }}</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7">{{ 'admin.band.none'|trans }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

    </main>
{% endblock %}

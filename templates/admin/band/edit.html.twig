{% extends 'base.html.twig' %}

{% block title %}{{ parent() }} - {{ 'admin.band.edit_title'|trans }} {{ band.name }}{% endblock %}

{% block body %}
    <main class="adminForms container-md">

        <h1 class="text-center"><span class="text-primary">{{ band.name }}</span> - {{ 'admin.band.edit_title'|trans }}</h1>

        {{ include('/admin/band/_form.html.twig', {'button_label': 'action.save'|trans}) }}

        <div class="d-flex flex-row justify-content-start">
            <a class="btn btn-primary me-1" href="{{ path('admin_band_index') }}">{{ 'action.back_to_bands'|trans }}</a>
            {{ include('/admin/band/_delete_form.html.twig') }}
        </div>
    </main>
{% endblock %}

<section id="contact" class="homeSection py-5" aria-labelledby="home-contact-title">
    <div class="container-xl">
        <div class="row gy-4 gy-lg-0 align-items-start">
            <div class="col-12 col-lg-5">
                <span class="homeSectionEyebrow">{{ 'home.contact_section.eyebrow'|trans }}</span>
                <h2 id="home-contact-title" class="homeSectionTitle">{{ 'home.contact'|trans }}</h2>
                <p class="homeSectionIntro mb-4">{{ 'home.contact_section.intro'|trans }}</p>

                <div class="homeContactDetails d-grid gap-3">
                    <div class="d-flex align-items-center gap-3">
                        <span class="homeContactIcon" aria-hidden="true">@</span>
                        <div>
                            <p class="homeContactLabel mb-1">{{ 'home.contact_section.email_label'|trans }}</p>
                            <a href="mailto:{{ association.getAssociation.email }}">{{ association.getAssociation.email }}</a>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <span class="homeContactIcon" aria-hidden="true">☎</span>
                        <div>
                            <p class="homeContactLabel mb-1">{{ 'home.contact_section.phone_label'|trans }}</p>
                            <a href="tel:{{ association.getAssociation.phone|replace({' ': ''}) }}">{{ association.getAssociation.phone }}</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-6 offset-lg-1">
                <div class="homeContactPanel">
                    {{ form_start(contactForm, {'attr': {'class': 'homeContactForm'}}) }}
                        <div class="row g-3">
                            <div class="col-12">
                                <div class="homeContactField">
                                    {{ form_label(contactForm.name, null, {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(contactForm.name, {'attr': {'class': 'form-control homeContactControl'}}) }}
                                    {{ form_errors(contactForm.name) }}
                                </div>
                            </div>
                            <div class="col-12 col-lg-6">
                                <div class="homeContactField">
                                    {{ form_label(contactForm.email, null, {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(contactForm.email, {'attr': {'class': 'form-control homeContactControl'}}) }}
                                    {{ form_errors(contactForm.email) }}
                                </div>
                            </div>
                            <div class="col-12 col-lg-6">
                                <div class="homeContactField">
                                    {{ form_label(contactForm.phone, null, {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(contactForm.phone, {'attr': {'class': 'form-control homeContactControl'}}) }}
                                    {{ form_errors(contactForm.phone) }}
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="homeContactField homeContactMessage">
                                    {{ form_label(contactForm.message, null, {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(contactForm.message) }}
                                    {{ form_errors(contactForm.message) }}
                                </div>
                            </div>
                            <div class="col-12">
                                {{ form_widget(contactForm.save, {'attr': {'class': 'btn homeContactSubmit w-100'}}) }}
                            </div>
                        </div>
                    {{ form_end(contactForm) }}
                </div>
            </div>
        </div>
    </div>
</section>

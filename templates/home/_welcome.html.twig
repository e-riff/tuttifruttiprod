<section id="welcome">
    {% set currentAssociation = association.getAssociation %}
    {% set heroImage = vich_uploader_asset(currentAssociation, 'heroImageFile') %}
    {% set heroTitle = currentAssociation.heroTitle ?: currentAssociation.name %}
    {% set heroSubtitle = currentAssociation.heroSubtitle ?: currentAssociation.description %}

    <div class="homeHero">
        <img
                src="{{ heroImage ?: asset('build/images/concert.jpg') }}"
                alt="{{ heroTitle }}"
                class="homeHeroImage"
        >
        <div class="homeHeroOverlay"></div>

        <div class="homeHeroContent">
            <span class="homeHeroEyebrow">{{ 'home.eyebrow'|trans }}</span>
            <h1>{{ heroTitle }}</h1>
            {% if heroSubtitle %}
                <p>{{ heroSubtitle }}</p>
            {% endif %}
            <div class="homeHeroActions">
                <a href="{{ path('band_index') }}" class="btn homeHeroPrimary">{{ 'home.groups'|trans }}</a>
                <a href="{{ path('app_concert_index') }}" class="btn homeHeroSecondary">{{ 'home.agenda'|trans }}</a>
            </div>
        </div>
    </div>
</section>

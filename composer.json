{
    "name": "tuttifrutti/tuttifrutti",
    "description": "",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/dbal": "^4",
        "doctrine/doctrine-bundle": "^3",
        "doctrine/doctrine-migrations-bundle": "^4",
        "doctrine/orm": "^3",
        "fakerphp/faker": "*",
        "friendsofsymfony/ckeditor-bundle": "^2.8",
        "liip/imagine-bundle": "^2.10",
        "phpdocumentor/reflection-docblock": "^6.0",
        "phpstan/phpdoc-parser": "^2.3",
        "spatie/calendar-links": "^2.0",
        "stof/doctrine-extensions-bundle": "^1.12",
        "symfony/apache-pack": "^1.0",
        "symfony/asset": "^8.1",
        "symfony/console": "^8.1",
        "symfony/doctrine-messenger": "^8.1",
        "symfony/dotenv": "^8.1",
        "symfony/expression-language": "^8.1",
        "symfony/flex": "^2",
        "symfony/form": "^8.1",
        "symfony/framework-bundle": "^8.1",
        "symfony/google-mailer": "^8.1",
        "symfony/html-sanitizer": "^8.1",
        "symfony/http-client": "^8.1",
        "symfony/intl": "^8.1",
        "symfony/mailer": "^8.1",
        "symfony/mime": "^8.1",
        "symfony/monolog-bundle": "^4.0",
        "symfony/notifier": "^8.1",
        "symfony/process": "^8.1",
        "symfony/property-access": "^8.1",
        "symfony/property-info": "^8.1",
        "symfony/runtime": "*",
        "symfony/security-bundle": "^8.1",
        "symfony/serializer": "^8.1",
        "symfony/string": "^8.1",
        "symfony/translation": "^8.1",
        "symfony/twig-bundle": "^8.1",
        "symfony/ux-live-component": "^3.1",
        "symfony/ux-twig-component": "^3.1",
        "symfony/validator": "^8.1",
        "symfony/web-link": "^8.1",
        "symfony/webpack-encore-bundle": "^2.4",
        "symfony/yaml": "^8.1",
        "symfonycasts/reset-password-bundle": "^1.23",
        "twig/extra-bundle": "^2.12|^3.0",
        "twig/twig": "^2.12|^3.0",
        "vich/uploader-bundle": "^2.0"
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true,
            "phpro/grumphp": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "ckeditor:install --tag=4.22.1": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": true,
            "require": "^8.1"
        }
    },
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "^4",
        "friendsofphp/php-cs-fixer": "^3.92",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-doctrine": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^13.2",
        "rector/rector": "^2.2",
        "squizlabs/php_codesniffer": "^4.0",
        "symfony/browser-kit": "^8.1",
        "symfony/css-selector": "^8.1",
        "symfony/debug-bundle": "^8.1",
        "symfony/maker-bundle": "^1.0",
        "symfony/phpunit-bridge": "^8.1",
        "symfony/stopwatch": "^8.1",
        "symfony/web-profiler-bundle": "^8.1"
    }
}
